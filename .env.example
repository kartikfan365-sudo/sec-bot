# Discord Settings
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Database Settings
MONGODB_URI=mongodb://localhost:27017/discord-sec-bot

# Dashboard Settings
PORT=5000
DASHBOARD_URL=http://localhost:5000
SESSION_SECRET=some_long_random_session_secret_string
# Secret used to encrypt/decrypt downloaded backup JSONs (optional but good practice)
BACKUP_ENCRYPTION_KEY=some_32_character_hex_key_here
